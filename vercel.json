{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/multiplayer/signaling/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ably/token.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ably/token",
      "dest": "/api/ably/token.js"
    },
    {
      "src": "/api/rooms/(.*)",
      "dest": "/src/multiplayer/signaling/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
